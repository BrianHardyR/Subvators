<style>
:root{--green-950:#012d12;--green-900:#01331a;--green-700:#1b4e21;--burgundy-900:#611412;--burgundy-800:#701011;--gold-400:#f2bf48;--cream-100:#fbfaf5;--cream-200:#f3f1ed;--cream-300:#e7e1d3;--ink:#101510;--muted:#596258;--line:rgba(16,21,16,.14);--ease:cubic-bezier(.16,1,.3,1)}*{box-sizing:border-box}html{overflow-x:clip}body{margin:0;min-width:320px;overflow-x:clip;background:linear-gradient(90deg,rgba(97,20,18,.08) 1px,transparent 1px),linear-gradient(0deg,rgba(1,51,26,.06) 1px,transparent 1px),#dedbd2;background-size:72px 72px;color:var(--ink);font-family:Montserrat,Arial,sans-serif;line-height:1.5}img{display:block;width:100%;height:100%;object-fit:cover}.page-frame{width:min(1500px,calc(100% - 36px));margin:18px auto;border:1px solid rgba(16,21,16,.16);background:var(--cream-100);box-shadow:0 34px 120px rgba(16,21,16,.18);overflow:hidden}.mock-header{display:flex;align-items:center;justify-content:space-between;gap:18px;min-height:78px;padding:16px clamp(18px,4vw,58px);border-bottom:1px solid var(--line);background:rgba(251,250,245,.9);backdrop-filter:blur(18px)}.brand{display:flex;align-items:center;gap:12px;font-weight:950}.brand-mark{display:grid;place-items:center;width:48px;height:48px;border:1px solid rgba(1,51,26,.18);border-radius:999px;background:#fff;color:var(--burgundy-800);font-size:.72rem}.brand small{display:block;color:var(--muted);font-size:.76rem}.nav{display:flex;gap:22px;color:var(--muted);font-size:.78rem;font-weight:900;text-transform:uppercase;letter-spacing:.06em}.section-label{margin:0 0 16px;color:var(--burgundy-800);font-size:.74rem;font-weight:950;letter-spacing:.06em;text-transform:uppercase}.evidence-section{display:grid;grid-template-columns:minmax(280px,.58fr) minmax(0,1fr);gap:clamp(34px,6vw,88px);align-items:end;padding:clamp(48px,6vw,82px) clamp(18px,4vw,58px);background:var(--green-950);color:#fff}.evidence-section .section-label{color:var(--gold-400)}.evidence-intro h2{max-width:620px;margin:0 0 18px;font-family:Georgia,ser