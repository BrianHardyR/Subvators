s{display:flex;flex-wrap:wrap;justify-content:flex-end;gap:10px}.stream-pills span{display:inline-flex;align-items:center;min-height:40px;padding:9px 13px;border:1px solid rgba(16,21,16,.14);border-radius:999px;background:rgba(251,250,245,.78);color:var(--ink);font-size:.72rem;font-weight:950;text-transform:uppercase;box-shadow:0 8px 28px rgba(1,45,18,.06)}.stream-pills span:first-child{background:var(--green-900);border-color:var(--green-900);color:#fff}.mosaic-stage{position:relative;display:grid;grid-template-columns:repeat(12,minmax(0,1fr));grid-template-rows:repeat(8,minmax(62px,6.6vw));gap:10px;min-height:680px;perspective:1200px}.mosaic-tile{position:relative;margin:0;overflow:hidden;border:1px solid rgba(16,21,16,.14);background:#121712;box-shadow:0 22px 70px rgba(1,45,18,.16);isolation:isolate;transform-origin:center;animation:tileIn 900ms var(--ease) both, tileFloat 7s ease-in-out infinite;animation-delay:var(--delay),calc(var(--delay) + 900ms)}.mosaic-tile:after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(1,45,18,0) 38%,rgba(1,45,18,.9));opacity:.92}.mosaic-tile:before{content:"";position:absolute;z-index:2;inset:0;border:1px solid rgba(242,191,72,0);transition:border-color 260ms ease}.mosaic-tile img{filter:saturate(.96) contrast(1.04);transform:scale(1.08);animation:kenBurns 16s ease-in-out infinite alternate;transition:transform 700ms var(--ease),filter 700ms var(--ease)}.mosaic-tile:hover{z-index:10;animation-play-state:paused;transform:translateY(-8px) scale(1.025)}.mosaic-tile:hover:before{border-color:rgba(242,191,72,.75)}.mosaic-tile:hover img{transform:scale(1.14);filter:saturate(1.08) contrast(1.08)}.caption{position:absolute;z-index:3;left:12px;right:12px;bottom:12px;display:flex;align-items:end;justify-content:space-between;gap:12px;color:#fff}.caption strong{max-width:260px;font-size:clamp(.82rem,1.16vw,1.15rem);line-height:1.05}.caption span{flex:0 0 auto;color:var(--gold-400);font-size:.68rem;font-weight:950;letter-spacing:.08em;text-transform:uppercase}.tile-a{grid-column:1/5;grid-row:1/4;border-radius:0 48px 0 0;--delay:40ms}.tile-b{grid-column:5/8;grid-row:1/3;--delay:120ms}.tile-c{grid-column:8/13;grid-row:1/5;border-radius:54px 0 0 0;--delay:200ms}.tile-d{grid-column:1/3;grid-row:4/7;--delay:280ms}.tile-e{grid-column:3/8;grid-row:3/7;border-radius:0 0 54px 0;--delay:360ms}.tile-f{grid-column:8/10;grid-row:5/9;--delay:440ms}.tile-g{grid-column:10/13;grid-row:5/8;border-radius:0 0 0 54px;--delay:520ms}.tile-h{grid-column:1/4;grid-row:7/9;border-radius:44px 0 0 0;--delay:600ms}.tile-i{grid-column:4/8;grid-row:7/9;--delay:680ms}.tile-j{grid-column:10/13;grid-row:8/9;--delay:760ms}.mosaic-center-note{grid-column:8/10;grid-row:8/9;display:grid;align-content:center;min-width:0;padding:12px;border:1px solid rgba(16,21,16,.14);background:var(--gold-400);color:#2d1502;font-size:.74rem;font-weight:950;line-height:1.2;text-transform:uppercase;box-shadow:0 18px 50px rgba(97,20,18,.18);animation:pulseNote 2400ms ease-in-out infinite}.mosaic-ribbon{position:absolute;z-index:4;left:-2%;right:-2%;bottom:36px;display:grid;grid-template-columns:repeat(9,minmax(72px,1fr));gap:8px;transform:rotate(-1.4deg);pointer-events:none;animation:ribbonDrift 18s linear infinite alternate}.ribbon-frame{height:86px;padding:5px;background:#fff;box-shadow:0 12px 34px rgba(16,21,16,.2)}.ribbon-frame img{filter:saturate(.92) contrast(1.02)}@keyframes tileIn{from{opacity:0;clip-path:inset(18% 18% 18% 18%);transform:translateY(28px) rotateX(8deg)}to{opacity:1;clip-path:inset(0);transform:translateY(0) rotateX(0)}}@keyframes tileFloat{0%,100%{translate:0 0}50%{translate:0 -7px}}@keyframes kenBurns{0%{transform:scale(1.08) translate3d(-1.5%,0,0)}100%{transform:scale(1.16) translate3d(1.5%,-1%,0)}}@keyframes pulseNote{0%,100%{transform:translateY(0);box-shadow:0 18px 50px rgba(97,20,18,.18)}50%{transform:translateY(-5px);box-shadow:0 26px 64px rgba(97,20,18,.25)}}@keyframes ribbonDrift{from{transform:translateX(-22px) rotate(-1.4deg)}to{transform:translateX(22px) rotate(-1.4deg)}}@media (prefers-reduced-motion:reduce){*,*:before,*:after{animation:none!important;transition:none!important}}@media(max-width:980px){.nav{display:none}.evidence-section{grid-template-columns:1fr}.stories-mosaic{grid-template-columns:1fr}.stories-rail{display:none}.mosaic-head{grid-template-columns:1fr}.stream-pills{justify-content:flex-start}.mosaic-stage{grid-template-columns:repeat(6,1fr);grid-template-rows:repeat(10,92px);min-height:980px}.tile-a{grid-column:1/4;grid-row:1/4}.tile-b{grid-column:4/7;grid-row:1/3}.tile-c{grid-column:4/7;grid-row:3/6}.tile-d{grid-column:1/3;grid-row:4/7}.tile-e{grid-column:3/5;grid-row:6/9}.tile-f{grid-column:5/7;grid-row:6/9}.tile-g{grid-column:1/4;grid-row:7/10}.tile-h{grid-column:4/7;grid-row:9/11}.tile-i{grid-column:1/3;grid-row:10/11}.tile-j{grid-column:3/5;grid-row:10/11}.mosaic-center-note{grid-column:5/7;grid-row:9/10}.mosaic-ribbon{position:relative;left:auto;right:auto;bottom:auto;grid-template-columns:repeat(4,1fr);transform:none;animation:none}}@media(max-width:560px){.page-frame{width:calc(100% - 18px);margin:9px auto}.mock-header,.evidence-section,.stories-mosaic{padding-left:16px;padding-right:16px}.evidence-intro h2,.mosaic-copy h2{font-size:3rem}.evidence-stack{grid-template-columns:1fr;grid-auto-rows:220px}.evidence-panel:first-child{grid-row:auto}.mosaic-stage{display:flex;min-height:0;overflow-x:auto;gap:12px;scroll-snap-type:x mandatory;padding-bottom:12px}.mosaic-tile{flex:0 0 82%;height:360px;scroll-snap-align:start}.mosaic-center-note{flex:0 0 62%;height:160px}.mosaic-ribbon{grid-template-columns:repeat(2,1fr)}.stream-pills span{font-size:.68rem}}
